# =============================================================================
# TukiJuris — Production environment template
# =============================================================================
# Copy to .env.production and fill EVERY value before deploying.
# Generate strong secrets with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# WARNING: this file is .gitignored only for `.env.production`. The .example
# template is committed. Do NOT put real secrets here.
# =============================================================================

# === App ===
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.0.0
APP_BASE_URL=https://tukijuris.com.pe
UVICORN_WORKERS=2

# === Database ===
DB_USER=tukijuris
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=agente_derecho
DATABASE_URL=postgresql+asyncpg://tukijuris:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/agente_derecho
DATABASE_URL_SYNC=postgresql://tukijuris:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/agente_derecho

# === Redis ===
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# === Auth ===
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# === Encryption — BYOK (MANDATORY in production) ===
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOK_ENCRYPTION_KEY=CHANGE_ME_44_CHAR_FERNET_KEY

# === LLM defaults (provider keys are stored in DB via /admin?tab=claves) ===
DEFAULT_LLM_PROVIDER=google
DEFAULT_LLM_MODEL=gemini/gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
EMBEDDING_PROVIDER=google

# === OAuth2 — Google (configure in Google Cloud Console) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://tukijuris.com.pe/auth/callback/google

# === OAuth2 — Microsoft (optional) ===
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://tukijuris.com.pe/auth/callback/microsoft
MICROSOFT_OAUTH_TENANT_ID=common

# === Payment — Culqi (sole provider in PE) ===
# Sandbox first: pk_test_xxx / sk_test_xxx. Switch to pk_live_xxx / sk_live_xxx after Culqi habilita.
CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=
CULQI_WEBHOOK_SECRET=
NEXT_PUBLIC_CULQI_PUBLIC_KEY=

# === Email — Resend ===
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=TukiJuris <noreply@tukijuris.com.pe>
EMAIL_ENABLED=true

# === Monitoring ===
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json

# === CORS + URLs ===
CORS_ORIGINS=["https://tukijuris.com.pe","https://www.tukijuris.com.pe"]
FRONTEND_URL=https://tukijuris.com.pe
PAYMENT_PORTAL_RETURN_URL=https://tukijuris.com.pe/billing

# === Web build args (baked into the client bundle) ===
NEXT_PUBLIC_API_URL=https://tukijuris.com.pe
NEXT_PUBLIC_APP_URL=https://tukijuris.com.pe

# === Cookies ===
# Apex-only deploy ⇒ leave empty for host-only cookies.
# Set to ".tukijuris.com.pe" only if cookies must be shared across subdomains.
COOKIE_DOMAIN=

# === Feature flags ===
# Must be explicit in production — startup_validation refuses to boot without this.
# BETA_MODE=true  → all features unlocked, free tier still capped, BYOK still pro/studio only.
# BETA_MODE=false → strict plan gating, webhook secrets become MANDATORY.
BETA_MODE=true

# Trials: enable once Culqi habilita y tokenización frontend está deployada (FASE 2).
TRIALS_ENABLED=false

# Scheduler: keep TRUE on the primary API container. If you scale to >1 API container,
# set to FALSE on the secondary instances so only one schedules jobs.
SCHEDULER_ENABLED=true

# Internal tick token — shared secret for POST /internal/trials/tick.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_TICK_TOKEN=CHANGE_ME_INTERNAL_TICK_TOKEN
