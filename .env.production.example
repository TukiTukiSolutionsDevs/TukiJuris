# === App ===
APP_ENV=production
APP_DEBUG=false
APP_VERSION=0.3.0

# === Database (CHANGE THESE) ===
DATABASE_URL=postgresql+asyncpg://user:STRONG_PASSWORD@db:5432/agente_derecho
DATABASE_URL_SYNC=postgresql://user:STRONG_PASSWORD@db:5432/agente_derecho
DB_USER=agente_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=agente_derecho

# === Redis ===
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# === Auth ===
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === LLM (at least one required) ===
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_LLM_PROVIDER=google
DEFAULT_LLM_MODEL=gemini-2.0-flash

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# === OAuth2 ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://tukijuris.net.pe/auth/callback/google
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://tukijuris.net.pe/auth/callback/microsoft

# === Email ===
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
EMAIL_FROM=TukiJuris <noreply@tukijuris.net.pe>
EMAIL_ENABLED=true

# === Monitoring ===
SENTRY_DSN=https://xxx@sentry.io/xxx

# === CORS ===
CORS_ORIGINS=["https://tukijuris.net.pe","https://www.tukijuris.net.pe"]
FRONTEND_URL=https://tukijuris.net.pe
STRIPE_PORTAL_RETURN_URL=https://tukijuris.net.pe/billing
