# ============================================
# AGENTE DERECHO - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/agente_derecho
DATABASE_URL_SYNC=postgresql://postgres:postgres@db:5432/agente_derecho
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agente_derecho

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- LLM Providers (add the ones you want to use) ---
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=AIzaSyBpYfKoTMnjwrhp38hy0uLCEGehMP7IHKA

# --- Default LLM ---
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini

# --- Embeddings ---
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- App ---
APP_NAME=Agente Derecho
APP_ENV=development
APP_DEBUG=true
API_PORT=8000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- OAuth2 — Google ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback/google

# --- OAuth2 — Microsoft ---
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback/microsoft
MICROSOFT_OAUTH_TENANT_ID=common

# --- Payment (MercadoPago) ---
# Get credentials from: https://www.mercadopago.com.pe/developers
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# --- Payment (Culqi) ---
# Get credentials from: https://culqi.com
CULQI_PUBLIC_KEY=
CULQI_SECRET_KEY=

# --- Email ---
EMAIL_PROVIDER=console
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=TukiJuris <noreply@tukijuris.net.pe>

# --- Monitoring ---
SENTRY_DSN=

# --- Security ---
# IMPORTANT: Change JWT_SECRET in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
